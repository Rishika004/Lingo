GEMINI_API_KEY=your-gemini-api-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-key
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-linkedin-password
GITHUB_TOKEN=optional-increases-rate-limit

# LinkedIn OAuth (create app at https://developer.linkedin.com)
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret
LINKEDIN_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Session encryption (any 32+ char random string)
SESSION_SECRET=change-me-to-a-long-random-secret-string-32chars

# Apify token (for LinkedIn post scraping)
APIFY_TOKEN=your-apify-token
